      <column caption='Commerical Share' datatype='real' name='[Calculation_1798316416831507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [MSN] = &quot;TECCB&quot; THEN [Data] END) / SUM(IF [MSN] = &quot;TETCB&quot; THEN [Data] END) * 100' />
