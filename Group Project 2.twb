        <calculation class='tableau' formula='SUM(IF [MSN] = &quot;BMTCB&quot; THEN [Data] END)' />
      </column>
      <column caption='Geothermal' datatype='integer' name='[Calculation_1798316366110732]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [MSN] = &quot;GETCB&quot; THEN [Data] END)' />
